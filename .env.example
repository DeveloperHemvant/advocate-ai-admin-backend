# Legal AI Admin backend - Example environment variables
# Copy to .env and adjust as needed.

PORT=4000
JWT_SECRET=your-jwt-secret-change-in-production
LEGAL_AI_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Admin-panel–dedicated database (do not share with app API or AI agent).
# If set, this overrides DATABASE_URL before Prisma loads. Use ?schema=legal_ai.
# LEGAL_AI_ADMIN_DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_ai_admin?schema=legal_ai

# If LEGAL_AI_ADMIN_DATABASE_URL is not set, Prisma uses DATABASE_URL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_ai_admin?schema=legal_ai
